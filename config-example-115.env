# emby2Alist 环境变量配置模板 - 115网盘

# ========================================
# 核心配置
# ========================================

# Emby 服务器地址
# Docker 环境推荐使用 172.17.0.1 (docker0 网桥 IP)
# 非 Docker 使用 127.0.0.1
EMBY_HOST=http://172.17.0.1:8096

# Emby API Key
# 获取方式: Emby 后台 -> 设置 -> 高级 -> API 密钥
EMBY_API_KEY=your_emby_api_key_here

# ========================================
# Alist 配置
# ========================================

# Alist 内网地址
ALIST_ADDR=http://172.17.0.1:5244

# Alist Token
# 获取方式: Alist 后台 -> 设置 -> 其他 -> Token
ALIST_TOKEN=your_alist_token_here

# Alist 公网地址 (可选)
# 如果没有公网访问需求，与 ALIST_ADDR 保持一致
ALIST_PUBLIC_ADDR=http://172.17.0.1:5244

# Alist 签名功能
# 一般保持 false，除非在 Alist 中启用了签名
ALIST_SIGN_ENABLE=false

# 直链有效期 (小时)
# 仅在 ALIST_SIGN_ENABLE=true 时有效
ALIST_SIGN_EXPIRE_TIME=12

# ========================================
# 挂载路径配置
# ========================================

# rclone 挂载路径
# 这是 Emby 路径和 Alist 路径的差异部分
# 示例:
#   Emby 路径: /mnt/115/Movies/电影.mkv
#   Alist 路径: /Movies/电影.mkv (在 Alist 中显示)
#   则 MEDIA_MOUNT_PATH=/mnt/115
MEDIA_MOUNT_PATH=/mnt/115

# ========================================
# Docker 配置
# ========================================

# Docker 网络模式
# host: 使用宿主机网络 (推荐)
# bridge: 使用桥接网络 (需要端口映射)
NETWORK_MODE=host

# emby2Alist 代理端口
# 仅在 NETWORK_MODE=bridge 时使用
PROXY_PORT=8091

# ========================================
# 高级配置 (可选)
# ========================================

# 是否启用 Web 端播放 115 视频
# true: 启用代理模式 (解决跨域问题)
# false: 禁用 Web 端直链 (推荐使用客户端)
ENABLE_WEB_PROXY=false

# 重定向检测
# true: 返回 302 前检测链接有效性
# false: 直接返回 302 (更快)
REDIRECT_CHECK_ENABLE=false

# 回源处理
# true: 查询失败时使用原始 Emby 链接
# false: 查询失败时返回 500 错误
FALLBACK_USE_ORIGINAL=true

# ========================================
# 115 特定配置
# ========================================

# 115 网盘 Cookie (Web 播放增强，可选)
# 用于 Web 端播放 115 视频时的身份验证
# 获取方式: 浏览器登录 115.com，F12 -> Application -> Cookies
WEB_COOKIE_115=

# ========================================
# 路径映射 (高级用户)
# ========================================

# 如果 Emby 路径和 Alist 路径不是简单的前缀差异
# 需要使用路径映射功能，在 constant-pro.js 中配置

# 示例场景 1: 移除路径前缀
#   Emby: /media/CloudNAS/115/Movies/xxx
#   Alist: /Movies/xxx
#   映射: [0, 0, "/media/CloudNAS/115", ""]

# 示例场景 2: 替换路径片段
#   Emby: /mnt/115/TV/剧集/xxx
#   Alist: /电视剧/xxx
#   映射: [0, 0, "/mnt/115/TV/剧集", "/电视剧"]

# ========================================
# 日志配置
# ========================================

# 日志目录
LOG_DIR=/var/log/nginx

# 缓存目录
CACHE_DIR=/var/cache/nginx/emby

# ========================================
# 时区配置
# ========================================

TZ=Asia/Shanghai

# ========================================
# 注意事项
# ========================================

# 1. 修改配置后需要重启服务:
#    docker-compose restart
#    或
#    docker exec nginx-emby nginx -s reload

# 2. 查看日志:
#    docker logs -f nginx-emby

# 3. 测试连通性:
#    curl http://localhost:8091

# 4. 验证 302 重定向:
#    播放视频时，F12 -> Network -> 找到视频请求
#    应该看到 302 状态码和 Location 响应头

# 5. 常见问题:
#    - 500 错误: 检查 Alist Token 是否正确
#    - 无直链: 检查 mediaMountPath 配置
#    - Web 跨域: 启用 ENABLE_WEB_PROXY 或使用客户端
#    - 端口冲突: 修改 PROXY_PORT

# ========================================
# 配置模板版本
# ========================================

CONFIG_VERSION=1.0.0
GENERATED_AT=2024-01-01 00:00:00
